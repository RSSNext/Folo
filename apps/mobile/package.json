  "appName": "Folo",
  "expo": {
    "install": {
      "exclude": [
        "react-native-worklets"
      ]
    },
    "autolinking": {
      "nativeModulesDir": "./native"
    },
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "enabled": true,
        "exclude": [
          "react-native-track-player",
          "follow-native",
          "react-native-color-matrix-image-filters"
        ],
        "listUnknownPackages": false
      }
    }
  }
