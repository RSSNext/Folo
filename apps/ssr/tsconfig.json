{
  "compilerOptions": {
    "incremental": true,
    "target": "ES2022",
    "jsx": "react",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "Bundler",
    "paths": {
      "@src/*": ["./src/*"],
      "@client/*": ["./client/*"],
      "@locales/*": ["../../locales/*"]
    },
    "resolveJsonModule": true,
    "types": ["vite/client", "@follow/types/react", "@follow/types/global"],
    "allowJs": true,
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./index.ts",
    "./api/index.ts",
    "./scripts/**/*.ts",
    "tsdown.config.ts",
    "./client/**/*.ts",
    "./client/**/*.tsx",
    "vite.config.mts",
    "./tailwind.config.ts",
    "./helper/**/*.ts"
  ],
  "exclude": ["node_modules", "./src/**/*.worker.ts"]
}
